# Copy to .env and set POSTGRES_PASSWORD (strong secret). DATABASE_URL must use the same password.

# Must match the DB user created on first Postgres volume init for this environment (changing only .env later does not rename the role).
# Example: local dev often `hkjc`; another machine may use `hkjc_1` — use `docker exec … psql -c "\\du"` if unsure.
POSTGRES_USER=hkjc
POSTGRES_PASSWORD=
POSTGRES_DB=hkjc_dashboard

# Local Node: use localhost. Docker Compose: use hostname `postgres` so the backend container reaches the DB.
# DATABASE_URL=postgresql://hkjc:YOUR_PASSWORD@localhost:5432/hkjc_dashboard
# DATABASE_URL=postgresql://hkjc:YOUR_PASSWORD@postgres:5432/hkjc_dashboard

REDIS_URL=redis://redis:6379
PORT=4000

# Session cookie signing (required). Generate a new value for every deployment — do not reuse the example.
#   Node.js:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#   OpenSSL:  openssl rand -base64 48   (Git Bash on Windows includes openssl)
SESSION_SECRET=

# First admin only: used when dashboard_users is empty (first boot or fresh DB). Set in real .env before first start; remove after you have created users.
AUTH_INITIAL_USERNAME=admin
AUTH_INITIAL_PASSWORD=

# Optional: set true when serving HTTPS so the session cookie is Secure.
# SESSION_COOKIE_SECURE=true

HKJC_SOURCE_URL=https://racing.hkjc.com

# AI Recommendation tab (OpenAI-compatible Chat Completions; server-side only — never VITE_*).
# Required for POST /api/ai/analyze. Leave unset to return 503 from that endpoint.
# OPENAI_API_KEY=
# Base URL including /v1 (e.g. https://api.openai.com/v1 or your Azure/OpenAI-compatible endpoint).
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# When true (default), /api/ai/analyze uses JSON from the model + fixed Markdown template. Set false if your API rejects response_format json_object (legacy Markdown-only).
# OPENAI_FORCE_JSON=false
# Successful analyses are persisted to table hkjc_ai_analyses (see apps/backend/src/schema.sql); GET /api/ai/saved lists them, GET /api/ai/saved/:id reloads one.
# AI analyze: short-window odds-drop (“big money”) summary from hkjc_odds_snapshots (server-computed block in prompt).
# AI_MOMENTUM_WINDOW_MINUTES=60
# AI_MOMENTUM_MAX_SNAPSHOTS=40
# AI_MOMENTUM_DROP_PCT_MIN=12
# Optional absolute odds drop floor (same selection must still show odds falling).
# AI_MOMENTUM_ABS_DROP_MIN=0.35
# Browser → API: leave empty for same-origin /api (Vite dev proxies /api to the backend; Docker+Caddy uses empty in compose).
VITE_API_URL=
# When using Caddy on :80, use same host/port as the page, e.g. ws://localhost/ws (if/when the app exposes /ws).
VITE_WS_URL=ws://localhost:4000/ws

# Historical scraper settings (used by services/scraper when run from UI or CLI)
SCRAPER_CONCURRENCY=2
# Comma-separated ISO dates (YYYY-MM-DD). If unset, CLI uses latest HK Wed + Sun before today.
# SCRAPER_DATES=2026-04-02,2026-04-05
# When true (set by API), abort if any target date already has rows in results/dividends/events tables.
# SCRAPER_STRICT_NO_DUPLICATE=true
# Legacy: scrape the full static TARGET_DATES list in services/scraper with optional range filters below.
# SCRAPER_USE_LEGACY_TARGET_LIST=true
SCRAPER_START_DATE=
SCRAPER_END_DATE=

# Horse details scraper: skip horses already in DB. Set false to refresh all.
SCRAPER_HORSE_DETAILS_SKIP_SCRAPED=true
# Full refresh: npm run scraper:horse-details:refresh   (or --refresh)
# Comma-separated horse codes (e.g. from UI). If unset, default is DISTINCT horse_code from hkjc_horse_race_history.
# SCRAPER_HORSE_CODES=A123,B456
# Code list source when SCRAPER_HORSE_CODES is empty: "file" = horse_codes_unique.txt; anything else = DB (UI forces DB).
# SCRAPER_HORSE_CODES_SOURCE=file

# Optional: override path to services/scraper (defaults to ../../services/scraper from backend).
# Docker Compose backend image sets SCRAPER_ROOT=/app/services/scraper automatically in docker-compose.yml.
# SCRAPER_ROOT=C:/path/to/HKJC_Dashboard/services/scraper

# Live odds worker (HKJC GraphQL via @gikndue/hkjc-api). Snapshots stored in hkjc_odds_snapshots.
# Live odds worker: on by default. Set to false to disable polling HKJC.
# ODDS_SYNC_ENABLED=false
# ODDS_SYNC_INTERVAL_MS=10000
# Include QIN,QPL so Realtime can show pair matrices + history (snapshots store requested pool types).
# ODDS_SYNC_ODDS_TYPES=WIN,PLA,QIN,QPL
# Default: server does not poll until you arm a race (Realtime: Start interval) or run Sync all races (once).
# Set true to restore legacy behavior: poll every active race on each worker tick.
# ODDS_SYNC_LEGACY_FULL_INTERVAL=true
# When true, skip inserting a snapshot if the payload hash matches the latest row for that race (saves DB space).
# Default: every worker fetch inserts a row so Realtime charts advance observed_at even when HKJC odds are unchanged.
# ODDS_SNAPSHOT_INSERT_ONLY_ON_CHANGE=true
# Database admin: allow export + purge of hkjc_odds_snapshots rows (destructive). Default off.
# ODDS_SNAPSHOT_PURGE_ENABLED=true
