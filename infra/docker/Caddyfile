# SITE_ADDRESS is set in docker-compose (from .env). Caddy obtains TLS certs automatically (Let's Encrypt).
{$SITE_ADDRESS} {
	handle /api* {
		reverse_proxy backend:4000
	}
	handle /health {
		reverse_proxy backend:4000
	}
	handle /ws/council* {
		reverse_proxy backend:4000 {
			# Keep WebSocket upgrades stable through TLS termination.
			flush_interval -1
		}
	}
	handle {
		reverse_proxy frontend:5173
	}
}
