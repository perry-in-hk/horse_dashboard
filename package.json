{
  "name": "hkjc_dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "docker:build": "docker compose build --no-cache",
    "docker:up": "docker compose up -d",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "docker:rebuild": "docker compose build --no-cache && docker compose up -d",
    "docker:rebuild:backend": "docker compose build --no-cache backend && docker compose up -d backend",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "start:scraper": "npm --workspace services/scraper run start",
    "scraper:historical": "npm --workspace services/scraper run historical",
    "scraper:horse-details": "npm --workspace services/scraper run horse-details",
    "scraper:horse-details:refresh": "npm --workspace services/scraper run horse-details:refresh",
    "start:recommender": "npm --workspace services/recommender run start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
