# Match POSTGRES_* in root .env when using docker-compose Postgres on localhost:5432
DATABASE_URL=postgres://hkjc:__SET_PASSWORD_IN_DOT_ENV__@localhost:5432/hkjc_dashboard
REDIS_URL=redis://localhost:6379
PORT=4000

# Same as root .env when using Compose (backend loads this file or env from compose).
# Session cookie signing (required). Generate a new value — do not copy from examples online.
#   Node.js:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#   OpenSSL:  openssl rand -base64 48   (Git Bash on Windows includes openssl)
SESSION_SECRET=

# First admin when dashboard_users is empty. Set password in real .env before first backend start.
AUTH_INITIAL_USERNAME=admin
AUTH_INITIAL_PASSWORD=
